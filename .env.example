# Resend — https://resend.com/api-keys
# Domain must be verified in Resend: audienceactivator.ai
RESEND_API_KEY=re_xxxxxxxx

# Form notifications (demo request + Access Pricing gate)
FORMS_FROM_EMAIL=Audience Activator AI <notifications@audienceactivator.ai>
FORMS_TO_EMAIL=james@tredfi.com

# Legacy aliases still supported by the API routes
DEMO_FROM_EMAIL=Audience Activator AI <notifications@audienceactivator.ai>
DEMO_TO_EMAIL=james@tredfi.com

# Calendly inline embed URL (optional — defaults to james-tredfi scheduling page)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/james-tredfi/quick-demo-15-or-30-minutes

# ====================
# Live Outbound Agent (BDC Copilot demo)
# Same keys as sales assistant apps/marketing — already on Vercel project "marketing".
# Run: pnpm run sync:live-callback-env
# ====================
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
# Or use shared phone number id:
ELEVENLABS_AGENT_PHONE_NUMBER_ID_SHARED=

# Profile-specific agent IDs (optional — each falls back to shared/legacy ids below)
ELEVENLABS_AGENT_ID_INBOUND_QUALIFIER=
ELEVENLABS_AGENT_ID_OUTBOUND_REACTIVATION=
ELEVENLABS_AGENT_ID_APPOINTMENT_RESCUE=
ELEVENLABS_AGENT_ID_TRADE_IN=
ELEVENLABS_AGENT_ID_FINANCE_HANDOFF=

# Legacy/shared fallbacks (marketing project uses these today)
ELEVENLABS_AGENT_ID_SHARED=
ELEVENLABS_AGENT_ID_PRIME=
ELEVENLABS_AGENT_ID_NEAR_PRIME=
ELEVENLABS_AGENT_ID_FIRST_TIME_SUBPRIME=

# Optional Maya / Avery / Eric voice overrides
ELEVENLABS_VOICE_ID_MAYA=
ELEVENLABS_VOICE_ID_AVERY=
ELEVENLABS_VOICE_ID_ERIC=
ELEVENLABS_VOICE_ID_SHARED=

# Twilio — call status polling after outbound dial
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Optional lead recap webhook
MARKETING_LEAD_NOTIFY_WEBHOOK_URL=
MARKETING_LEAD_NOTIFY_WEBHOOK_SECRET=
